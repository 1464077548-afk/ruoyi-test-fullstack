<?xml version='1.0' encoding='UTF-8'?>
<project>
  <description>若依全栈自动化测试 - Phase 1: API and UI (Parallel) | Phase 2: Performance (Serial)</description>
  <keepDependencies>false</keepDependencies>
  <properties/>
  <scm class="hudson.plugins.git.GitSCM" plugin="git@5.4.1">
    <userRemoteConfigs>
      <hudson.plugins.git.UserRemoteConfig>
        <url>REPLACE_WITH_YOUR_GIT_REPO_URL</url>
      </hudson.plugins.git.UserRemoteConfig>
    </userRemoteConfigs>
    <branches>
      <hudson.plugins.git.BranchSpec>
        <name>*/main</name>
      </hudson.plugins.git.BranchSpec>
    </branches>
    <doGenerateSubmoduleConfigurations>false</doGenerateSubmoduleConfigurations>
    <submoduleCfg class="list"/>
    <extensions/>
  </scm>
  <canRoam>true</canRoam>
  <disabled>false</disabled>
  <blockBuildWhenDownstreamBuilding>false</blockBuildWhenDownstreamBuilding>
  <blockBuildWhenUpstreamBuilding>false</blockBuildWhenUpstreamBuilding>
  <triggers>
    <hudson.triggers.TimerTrigger>
      <spec>H 2 * * *</spec>
    </hudson.triggers.TimerTrigger>
  </triggers>
  <concurrentBuild>false</concurrentBuild>
  <builders>
    <hudson.tasks.BatchFile>
      <command>call E:\ruoyi-ui\ruoyi_fullstack_test\run_api_ui_tests.bat</command>
      <unstableReturnCode>0</unstableReturnCode>
    </hudson.tasks.BatchFile>
    <hudson.tasks.BatchFile>
      <command>call E:\ruoyi-ui\ruoyi_fullstack_test\run_performance_tests.bat</command>
      <unstableReturnCode>0</unstableReturnCode>
    </hudson.tasks.BatchFile>
  </builders>
  <publishers>
    <hudson.tasks.junit.JUnitResultArchiver>
      <testResults>E:\ruoyi-ui\ruoyi_fullstack_test\reports\junit\junit_api_ui.xml</testResults>
      <healthScaleFactor>1.0</healthScaleFactor>
      <allowEmptyResults>true</allowEmptyResults>
      <keepLongStdio>false</keepLongStdio>
      <healthEnabled>true</healthEnabled>
      <ignoreBlankFiles>false</ignoreBlankFiles>
    </hudson.tasks.junit.JUnitResultArchiver>
    <htmlpublisher.HtmlPublisher>
      <reportTargets>
        <htmlpublisher.HtmlPublisherTarget>
          <reportName>Phase-1-API-UI-Report</reportName>
          <reportDir>E:\ruoyi-ui\ruoyi_fullstack_test\reports\html</reportDir>
          <reportFiles>report_api_ui.html</reportFiles>
          <keepAll>true</keepAll>
          <alwaysLinkToLastBuild>true</alwaysLinkToLastBuild>
          <allowMissing>false</allowMissing>
        </htmlpublisher.HtmlPublisherTarget>
      </reportTargets>
    </htmlpublisher.HtmlPublisher>
    <hudson.tasks.junit.JUnitResultArchiver>
      <testResults>E:\ruoyi-ui\ruoyi_fullstack_test\reports\junit\junit_performance.xml</testResults>
      <healthScaleFactor>1.0</healthScaleFactor>
      <allowEmptyResults>true</allowEmptyResults>
      <keepLongStdio>false</keepLongStdio>
      <healthEnabled>true</healthEnabled>
      <ignoreBlankFiles>false</ignoreBlankFiles>
    </hudson.tasks.junit.JUnitResultArchiver>
    <htmlpublisher.HtmlPublisher>
      <reportTargets>
        <htmlpublisher.HtmlPublisherTarget>
          <reportName>Phase-2-Performance-Report</reportName>
          <reportDir>E:\ruoyi-ui\ruoyi_fullstack_test\reports\html</reportDir>
          <reportFiles>report_performance.html</reportFiles>
          <keepAll>true</keepAll>
          <alwaysLinkToLastBuild>true</alwaysLinkToLastBuild>
          <allowMissing>true</allowMissing>
        </htmlpublisher.HtmlPublisherTarget>
      </reportTargets>
    </htmlpublisher.HtmlPublisher>
    <allure.jenkins.tool.AllureReportPublisher>
      <reportVersion>2</reportVersion>
      <results>
        <allure.jenkins.tool.AllureReportPublisher_-Result>
          <glob>E:\ruoyi-ui\ruoyi_fullstack_test\reports\allure_api_ui\**\allure-*.xml</glob>
        </allure.jenkins.tool.AllureReportPublisher_-Result>
      </results>
    </allure.jenkins.tool.AllureReportPublisher>
    <hudson.plugins.emailext.ExtendedEmailPublisher>
      <recipientList>hejianping911@163.com</recipientList>
      <configuredTriggers>
        <hudson.plugins.emailext.trigger.FailureTrigger>
          <email>
            <subject>[Jenkins] ${BUILD_STATUS} - ${PROJECT_NAME} - Build #${BUILD_NUMBER}</subject>
            <body>$DEFAULT_CONTENT</body>
            <recipientList>hejianping911@163.com</recipientList>
            <sendToDevelopers>false</sendToDevelopers>
            <sendToRequester>false</sendToRequester>
            <includeCulprits>false</includeCulprits>
            <sendToRecipientList>true</sendToRecipientList>
          </email>
        </hudson.plugins.emailext.trigger.FailureTrigger>
        <hudson.plugins.emailext.trigger.AlwaysTrigger>
          <email>
            <subject>[Jenkins] ${BUILD_STATUS} - ${PROJECT_NAME} - Build #${BUILD_NUMBER}</subject>
            <body>$DEFAULT_CONTENT</body>
            <recipientList>hejianping911@163.com</recipientList>
            <sendToDevelopers>false</sendToDevelopers>
            <sendToRequester>false</sendToRequester>
            <includeCulprits>false</includeCulprits>
            <sendToRecipientList>true</sendToRecipientList>
          </email>
        </hudson.plugins.emailext.trigger.AlwaysTrigger>
      </configuredTriggers>
      <contentType>text/html</contentType>
      <defaultSubject>[Jenkins] ${BUILD_STATUS} - ${PROJECT_NAME}</defaultSubject>
      <defaultContent>$DEFAULT_CONTENT</defaultContent>
      <attachmentsPattern></attachmentsPattern>
      <presendScript></presendScript>
      <postsendScript></postsendScript>
      <attachBuildLog>false</attachBuildLog>
      <compressFile>false</compressFile>
      <replyTo></replyTo>
      <saveOutput>false</saveOutput>
      <disabled>false</disabled>
    </hudson.plugins.emailext.ExtendedEmailPublisher>
  </publishers>
  <buildWrappers>
    <hudson.plugins.timestamper.TimestamperBuildWrapper/>
  </buildWrappers>
</project>
