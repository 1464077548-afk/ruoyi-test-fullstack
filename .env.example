# 若依全栈测试环境配置示例
# 复制此文件为 .env 并根据您的环境修改配置

# 基础URL配置
BASE_URL=http://localhost:80
API_BASE_URL=http://localhost:8080

# 测试账号配置
TEST_USERNAME=admin
TEST_PASSWORD=admin123

# 数据库配置（本地运行时使用 localhost）
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ry-vue
DB_USERNAME=root
DB_PASSWORD=123456

# Redis配置
REDIS_PORT=6379

# 浏览器配置
BROWSER=chromium
HEADLESS=false
SLOW_MO=0

# 超时设置（秒）
PAGE_LOAD_TIMEOUT=30
ELEMENT_TIMEOUT=10
UI_TIMEOUT=60

# 性能测试配置
LOCUST_HOST=http://localhost:8080
LOCUST_USERS=100
LOCUST_SPAWN_RATE=10

# 安全测试配置
SECURITY_SCAN_ENABLED=true
SECURITY_SCAN_DEPTH=2

# 报告配置
REPORT_DIR=reports
DATA_DIR=data